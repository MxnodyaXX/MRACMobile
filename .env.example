# Copy this file to `.env` and fill in the values.
# Only EXPO_PUBLIC_* vars are exposed to the app bundle.

# Supabase (same project as the EMRAC web app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Phone that receives internal admin/staff SMS alerts (optional)
EXPO_PUBLIC_ADMIN_PHONE=

# Optional: pin the LAN IP so `npx expo start` shows a QR your phone can reach
# (avoids Expo picking a VirtualBox/virtual adapter). Set to your PC's Wi-Fi IPv4.
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.100
